# --- Obrigatório ---
# Provedor: openai | openrouter
PROVIDER=openai

# Modelo padrão
# OpenAI (recomendado para custo/qualidade): gpt-4o-mini
# OpenRouter exemplos: openai/gpt-4o-mini  |  anthropic/claude-3.5-sonnet
MODEL=gpt-4o-mini

# Sua chave de API (NUNCA exponha no frontend)
API_KEY=sk-coloque-sua-chave-aqui

# --- Opcional ---
# Códigos de acesso dos alunos (separados por vírgula).
# Se vazio, qualquer pessoa com a URL pode usar.
ACCESS_CODES=PSF-2025-ALUNO1,PSF-2025-ALUNO2

# Origem permitida (CORS). Use o domínio do seu site, ex: https://psiefica.com.br
ALLOW_ORIGIN=*

# Limite por janela
RATE_LIMIT=40
RATE_WINDOW_S=60

# Geração
MAX_TOKENS=900
TEMPERATURE=0.6

# Porta local
PORT=8787

# URL pública (usado só em headers do OpenRouter)
PUBLIC_URL=https://seu-dominio.com
